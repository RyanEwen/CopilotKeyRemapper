<?xml version="1.0" encoding="utf-8"?>

<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <!-- Identity from Partner Center. The build script swaps Publisher to the dev cert
       subject for local (sideload) dev builds; -NoSign keeps these real values for Store. -->
  <Identity
    Name="27766TechnicallyReal.CopilotKeyRemapper"
    Publisher="CN=C21E6CEF-D0D1-4497-93F9-3718D054DA0E"
    Version="VERSION_PLACEHOLDER"
    ProcessorArchitecture="ARCH_PLACEHOLDER" />

  <Properties>
    <DisplayName>Copilot Key Remapper</DisplayName>
    <PublisherDisplayName>TechnicallyReal</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22000.0" MaxVersionTested="10.0.26100.0" />
    <PackageDependency Name="Microsoft.WindowsAppRuntime.1.8" MinVersion="8000.770.947.0" Publisher="CN=Microsoft Corporation, O=Microsoft Corporation, L=Redmond, S=Washington, C=US" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <!-- Settings UI: the user-facing app, launched from the Start tile / Store.
         Not in the keypress path. -->
    <Application Id="Settings"
      Executable="CopilotKeyRemapper.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Copilot Key Remapper"
        BackgroundColor="transparent"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png"
        Description="Choose what your keyboard's Copilot key does - a custom shortcut, an app, or a Windows function.">
        <uap:SplashScreen Image="Images\SplashScreen.png" />
      </uap:VisualElements>
    </Application>

    <!-- Copilot key handler: the tiny Native exe Windows launches on the key press.
         Registered as the Copilot hardware-key provider + protocol handler. Its id is
         "App" so the user's key assignment (AppAumid = ...!App) is preserved across
         updates. Hidden from the Start menu; it just runs the action and exits. -->
    <Application Id="App"
      Executable="CopilotKeyRemapperKey.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        AppListEntry="none"
        DisplayName="Copilot Key Remapper"
        BackgroundColor="transparent"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png"
        Description="Runs the action you assigned to the Copilot key." />
      <Extensions>
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="copilotkeyremapper-key">
            <uap:DisplayName>Copilot Key Remapper key</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.windows.copilotkeyprovider"
            Id="CopilotKeyRemapper"
            DisplayName="Copilot Key Remapper"
            Description="Run a shortcut, app, or Windows function"
            PublicFolder="Public">
            <uap3:Properties>
              <SingleTap MessageWParam="0">copilotkeyremapper-key://?state=Tap</SingleTap>
              <PressAndHoldStart MessageWParam="1">copilotkeyremapper-key://?state=Down</PressAndHoldStart>
              <PressAndHoldStop MessageWParam="2">copilotkeyremapper-key://?state=Up</PressAndHoldStop>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Only used when the user clicks "Check for updates" in the About page. -->
    <Capability Name="internetClient" />
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
