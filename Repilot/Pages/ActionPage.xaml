<Page
    x:Class="Repilot.Pages.ActionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Repilot.Models"
    xmlns:vm="using:Repilot.ViewModels">

    <Grid Padding="32,16,32,0" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Copilot key action" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Mode -->
        <SelectorBar Grid.Row="1" x:Name="ModeBar" SelectionChanged="ModeBar_SelectionChanged">
            <SelectorBarItem Text="Shortcut" Tag="KeyCombo">
                <SelectorBarItem.Icon><FontIcon Glyph="&#xE765;" /></SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem Text="App or link" Tag="LaunchApp">
                <SelectorBarItem.Icon><FontIcon Glyph="&#xE8E5;" /></SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem Text="Windows function" Tag="WindowsFunction">
                <SelectorBarItem.Icon><FontIcon Glyph="&#xE71D;" /></SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem Text="Nothing" Tag="None">
                <SelectorBarItem.Icon><FontIcon Glyph="&#xE711;" /></SelectorBarItem.Icon>
            </SelectorBarItem>
        </SelectorBar>

        <!-- Mode-specific config -->
        <Grid Grid.Row="3">

            <!-- KeyCombo -->
            <StackPanel x:Name="ComboPanel" Spacing="12" Visibility="Collapsed" VerticalAlignment="Top">
                <TextBlock TextWrapping="Wrap" Opacity="0.8"
                           Text="Click Record, then press the shortcut you want (e.g. Alt+Tab). The keys are captured here, not actually triggered. Press Esc to cancel." />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border x:Name="ComboBorder" MinWidth="240" Height="40" VerticalAlignment="Center"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12,0">
                        <TextBlock x:Name="ComboDisplay" VerticalAlignment="Center" Text="(not set)" />
                    </Border>
                    <Button x:Name="RecordButton" Content="Record shortcut" Click="RecordButton_Click"
                            LostFocus="RecordButton_LostFocus" />
                    <Button x:Name="ClearComboButton" Content="Clear" Click="ClearComboButton_Click" />
                </StackPanel>
            </StackPanel>

            <!-- LaunchApp: searchable app list + custom file/link -->
            <Grid x:Name="LaunchPanel" Visibility="Collapsed" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <AutoSuggestBox Grid.Row="0" x:Name="AppSearch" QueryIcon="Find"
                                PlaceholderText="Search apps…" TextChanged="AppSearch_TextChanged" />
                <ListView Grid.Row="1" x:Name="AppList" SelectionMode="Single"
                          SelectionChanged="AppList_SelectionChanged"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:InstalledApp">
                            <Grid ColumnSpacing="12" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{x:Bind Icon, Mode=OneWay}" Width="24" Height="24" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Expander Grid.Row="2" Header="Open a file or link instead" HorizontalAlignment="Stretch">
                    <StackPanel Spacing="8" Width="520" HorizontalAlignment="Left">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LaunchPathBox" Header="Path or link"
                                     PlaceholderText="C:\… or https://… or ms-settings:…" TextChanged="LaunchPathBox_TextChanged" />
                            <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse…" VerticalAlignment="Bottom"
                                    Click="BrowseButton_Click" />
                        </Grid>
                        <TextBox x:Name="LaunchArgsBox" Header="Arguments (optional)" TextChanged="LaunchArgsBox_TextChanged" />
                    </StackPanel>
                </Expander>
            </Grid>

            <!-- None -->
            <TextBlock x:Name="NonePanel" Visibility="Collapsed" VerticalAlignment="Top" Opacity="0.8"
                       TextWrapping="Wrap" Text="Nothing happens for this gesture." />

            <!-- WindowsFunction -->
            <Grid x:Name="FunctionPanel" Visibility="Collapsed" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <AutoSuggestBox Grid.Row="0" x:Name="FunctionSearch" QueryIcon="Find"
                                PlaceholderText="Search functions (e.g. lock, snip, magnifier)…"
                                TextChanged="FunctionSearch_TextChanged" />
                <ListView Grid.Row="1" x:Name="FunctionList" SelectionMode="Single"
                          SelectionChanged="FunctionList_SelectionChanged"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Opacity="0.7" Margin="0,8,0,2" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:WindowsFunction">
                            <StackPanel Spacing="1" Padding="0,4">
                                <TextBlock Text="{x:Bind Name}" />
                                <TextBlock Text="{x:Bind Description}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
