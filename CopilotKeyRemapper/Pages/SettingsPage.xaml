<Page
    x:Class="CopilotKeyRemapper.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32,16,32,32">
        <StackPanel Spacing="8" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,8" />

            <!-- Theme -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="App theme" FontWeight="SemiBold" />
                        <TextBlock Text="Appearance of this settings window." Opacity="0.7" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Right" MinWidth="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="System default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </Grid>
            </Border>

            <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                     Title="No background process"
                     Message="Copilot Key Remapper doesn't run in the background. When you press the Copilot key, Windows briefly launches a tiny handler that performs your action and exits. This window is only for configuration." />
        </StackPanel>
    </ScrollViewer>
</Page>
